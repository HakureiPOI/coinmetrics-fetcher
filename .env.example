# CoinMetrics API 配置

# 专业版 API 密钥（如果使用社区版 API，此项可为空）
COINMETRICS_API_KEY=YOUR_API_KEY

# API 基础 URL (可选，默认：https://api.coinmetrics.io/v4)
# 社区版：https://community-api.coinmetrics.io/v4
# 专业版：https://api.coinmetrics.io/v4
# COINMETRICS_BASE_URL=https://api.coinmetrics.io/v4

# 使用社区版 API (可选，默认：false)
# 设置为 true 时，无需配置 COINMETRICS_API_KEY
# COINMETRICS_USE_COMMUNITY_API=false

# 请求超时时间 (秒，默认：30)
# COINMETRICS_TIMEOUT=30

# 分页大小默认值 (1-10000，默认：10000)
# COINMETRICS_PAGE_SIZE=10000

# 最大重试次数 (默认：3)
# COINMETRICS_MAX_RETRIES=3

# 请求间隔 (秒，用于速率限制，默认：0)
# COINMETRICS_RATE_LIMIT_DELAY=0

# 日志级别 (默认：INFO)
# LOG_LEVEL=INFO

# 日志文件路径 (可选，不设置则仅输出到控制台)
# LOG_FILE=logs/coinmetrics.log